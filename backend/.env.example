# ── beatscanner backend environment variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.

# ── FMP (Financial Modeling Prep) ─────────────────────────────────────────────
# Your own FMP API key (free tier works for all features).
# Get one at: https://financialmodelingprep.com/register
FMP_API_KEY=your_fmp_api_key_here

# API key used for the demo endpoint (no user key required).
# Use your own FMP key or a dedicated demo-only key.
FMP_DEMO_API_KEY=your_demo_fmp_key_here

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────────
# Required for AI決算詳報 and カンファレンス要点 features.
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# Dev defaults (http://localhost:5173) are built-in.
# Add your production frontend URL here when deploying.
# Example: ALLOWED_ORIGINS=https://beatscanner.vercel.app,https://beatscanner.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Static frontend (optional) ────────────────────────────────────────────────
# Absolute path to the compiled Vite output (frontend/dist).
# Only needed if you override the default relative-path detection.
# STATIC_DIR=/absolute/path/to/frontend/dist

# ── GitHub Actions / article generation ──────────────────────────────────────
BEATSCANNER_URL=https://beatscanner.vercel.app

# ── Future: auth + payments (not yet implemented) ─────────────────────────────
# These are placeholders for when Clerk + Lemon Squeezy are wired in.
# Do NOT add these to Railway/Vercel until the code is written.
#
# CLERK_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# LEMONSQUEEZY_API_KEY=...
# LEMONSQUEEZY_WEBHOOK_SECRET=...
# LEMONSQUEEZY_STORE_ID=...
# PRO_VARIANT_ID=...
# PREMIUM_VARIANT_ID=...
# DATABASE_URL=postgresql://...
