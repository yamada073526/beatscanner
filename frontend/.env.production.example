# BeatScanner frontend — build-time environment variables
# (Railway Service Variables の ARG として渡される、vite build 時に静的展開)
#
# このファイルはドキュメント用。実際の値は Railway / .env.local に設定すること。
# NEVER commit real values.

# ── Supabase (既存、Dockerfile ARG 済) ─────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── build-articles.mjs 用 (P3.1 新規) ──────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY が設定されている場合: RLS bypass で draft 記事もビルド対象
# 未設定の場合: VITE_SUPABASE_ANON_KEY を使用し published のみ対象 (RLS)
#
# Railway の Service Variables に設定する場合、Dockerfile Stage 1 に ARG 追加が必要:
#   ARG SUPABASE_SERVICE_ROLE_KEY
#   ENV SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_SERVICE_ROLE_KEY
#
# P3.1 では anon key 運用 (published のみ) が標準。
# service_role key を Railway に追加するのは P3 完了後の運用判断で実施。
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── 記事 canonical URL base (P3.3 で使用) ──────────────────────────────────────
# 未設定時は "https://beatscanner-production.up.railway.app" にフォールバック
VITE_PUBLIC_SITE_URL=https://beatscanner-production.up.railway.app
